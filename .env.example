# Copy this file to .env and fill in real values. Never commit .env.

# =====================================================================
# REQUIRED for local run
# =====================================================================

# --- LLM provider (extraction agents + validator) ---
# Generic key for whatever LLM_BASE_URL below points at — OpenRouter, Gemini's
# OpenAI-compat endpoint, Together, Groq, a self-hosted server behind auth, ...
# Leave blank for a local endpoint (Ollama/vLLM/LM Studio) — no key needed.
LLM_API_KEY=

# --- Supabase / PostgreSQL (docs, JSON, confidence, validation/retry logs) ---
# From Supabase project settings -> Database / API (new publishable/secret key system).
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Direct Postgres connection string (Settings -> Database -> Connection string -> URI)
DATABASE_URL=

# =====================================================================
# OPTIONAL — defaults work for local dev, fill in only if needed
# =====================================================================

# LLM model id for the endpoint below (defaults chosen in code if left blank —
# see pipeline/config.py DEFAULT_LLM_MODEL, assumes OpenRouter's naming).
LLM_MODEL=
# Ideally a DIFFERENT model from LLM_MODEL, so the extractor never grades its
# own homework. Blank = same as LLM_MODEL.
VALIDATOR_LLM_MODEL=

# LLM endpoint — any OpenAI-compatible server. Default (blank) is OpenRouter.
#   OpenRouter : https://openrouter.ai/api/v1                              (needs LLM_API_KEY)
#   Gemini     : https://generativelanguage.googleapis.com/v1beta/openai/  (needs LLM_API_KEY; LLM_MODEL=gemini-2.0-flash)
#   Ollama     : http://host.docker.internal:11434/v1                      (no key; pull a tool-calling instruct model first)
LLM_BASE_URL=

# OpenAI-client retries with exponential backoff on 429/5xx (honors Retry-After).
LLM_MAX_RETRIES=5
# Cap on concurrent LangGraph nodes. 0/blank = full 6-agent parallel fan-out;
# set 1 on rate-limited/free tiers so agents call the LLM one at a time.
PIPELINE_MAX_CONCURRENCY=0

# Embeddings / reranking (BAAI/bge-m3, bge-reranker-v2-m3) — run locally by
# default. Only set EMBEDDING_API_URL/KEY if using a hosted endpoint instead.
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
EMBEDDING_API_URL=
EMBEDDING_API_KEY=

# Qdrant (statute KB: IPC + Constitution) — runs locally via
# `docker compose up -d`, no API key needed for local dev.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=statutes

# Langfuse (tracing / reproducibility)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Data region: EU https://cloud.langfuse.com | US https://us.cloud.langfuse.com
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Docling / OCR
# Text-layer density threshold below which OCR fallback triggers (0-1).
DOCLING_OCR_DENSITY_THRESHOLD=0.1

# Pipeline / confidence thresholds
CONFIDENCE_AUTOSAVE_THRESHOLD=0.90
CONFIDENCE_REVIEW_THRESHOLD=0.80
MAX_RETRIES=3
